DJANGO_SECRET_KEY=replace-this-with-a-long-random-secret-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

POSTGRES_DB=facemap
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-your-postgres-password
